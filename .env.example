# Agile Artifact Analyzer - Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---------------------------------------------------------
# REQUIRED: PostgreSQL database connection string
# Format: postgresql://username:password@host:port/database
# ---------------------------------------------------------
DATABASE_URL=postgresql://artifact_user:yourpassword@localhost:5432/artifact_analyzer

# ---------------------------------------------------------
# REQUIRED: Secret key for encrypting user sessions
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ---------------------------------------------------------
SESSION_SECRET=change-this-to-a-long-random-string

# ---------------------------------------------------------
# REQUIRED: OpenAI API key for AI-powered analysis
# Get yours at: https://platform.openai.com/api-keys
# Must have access to: gpt-4o
# ---------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# ---------------------------------------------------------
# OPTIONAL: Server port (default: 5000)
# ---------------------------------------------------------
PORT=5000

# ---------------------------------------------------------
# OPTIONAL: Environment mode
# ---------------------------------------------------------
NODE_ENV=production
